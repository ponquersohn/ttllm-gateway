{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "TTLLM: Run API Server",
            "type": "debugpy",
            "request": "launch",
            "module": "ttllm.handlers.ecs_entrypoint",
            "console": "integratedTerminal",
            "env": {
                "TTLLM_DATABASE_URL": "postgresql+asyncpg://ttllm:dev@localhost:5432/ttllm"
            }
        }
    ]
}
